# Feishu bot credentials (from https://open.feishu.cn/app)
# Copy to .env and fill in. Do not commit .env.

FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# Optional but recommended: absolute Claude CLI path, so new shells/sessions
# do not depend on PATH.
# CLAUDE_CLI_PATH=/home/your_user/.local/bin/claude